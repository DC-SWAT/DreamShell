<?xml version="1.0" encoding="UTF-8"?>
<app name="Arcade" icon="images/icon.png" version="1.0.0">
    <resources>
        <module src="../../modules/minilzo.klf" />
        <module src="../../modules/isofs.klf" />
        <module src="../../modules/isoldr.klf" />
        <module src="../../modules/wave.klf" />
        <module src="../../modules/ffmpeg.klf" />
        <module src="modules/app_arcade.klf" />
        <font src="../../fonts/txf/dreamshell.txf" name="label_font" />
    </resources>
    <body type="tsunami" width="100%" height="100%" backgroundColor="#000000"
        onload="export:ArcadeApp_Init()"
        onopen="export:ArcadeApp_Open()"
        onclose="export:ArcadeApp_Close()"
        onunload="export:ArcadeApp_Shutdown()">

        <gradient x="0" y="0" width="100%" height="100%" z="1.0"
            topLeft="#222222" topRight="#222222" bottomLeft="#000000" bottomRight="#000000" />

        <image src="images/bg.png" x="64" y="237" width="512" height="256" z="64.99" transparent="true" />

        <wave name="wave" x="320" y="365" width="100%" height="140" z="65.0"
            freq="0.8" amp="13.0" speed="0.02" segs="32" duration="9000" hold="5000"
            color1="#FF0000E5" color2="#70C9DB66" transparent="true" />

        <circle name="fog_circle_0" radius="512.0" points="16" centerColor="#70C9DB66" edgeColor="#00000000" transparent="true" z="20.0" />
        <circle name="fog_circle_1" radius="512.0" points="16" centerColor="#70C9DB66" edgeColor="#00000000" transparent="true" z="30.0" />
        <circle name="fog_circle_2" radius="512.0" points="16" centerColor="#70C9DB66" edgeColor="#00000000" transparent="true" z="40.0" />
        <circle name="fog_circle_3" radius="512.0" points="16" centerColor="#70C9DB66" edgeColor="#00000000" transparent="true" z="50.0" />

        <rectangle name="video_border" x="190" y="40" width="260" height="260" z="99.5" transparent="false" color="#FFFFFFFF" />

        <label name="page_label" font="label_font" fontsize="10" text="" smear="true" color="#FFFFFF00" />
        <label name="coin_label" font="label_font" fontsize="10" text="" smear="true" color="#FFFFFF00" />
    </body>
</app>
